{
  "name": "cp-swiss-knife",
  "displayName": "CP Swiss Knife",
  "description": "Competitive Programming Swiss Knife — solve Codeforces problems in VS Code: browse problems, join contests, run local tests, submit solutions, and track your progress",
  "version": "0.3.1",
  "publisher": "albarham",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0D1B2A",
    "theme": "dark"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "keywords": [
    "codeforces",
    "competitive programming",
    "algorithm",
    "contest",
    "programming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammad-albarham/cp-swiss-knife"
  },
  "activationEvents": [
    "onView:codeforcesUserDashboard",
    "onView:codeforcesProblems",
    "onView:codeforcesContests",
    "onView:codeforcesSubmissions"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeforces.login",
        "title": "CP Swiss Knife: Login",
        "icon": "$(sign-in)"
      },
      {
        "command": "codeforces.logout",
        "title": "CP Swiss Knife: Logout",
        "icon": "$(sign-out)"
      },
      {
        "command": "codeforces.configureApiCredentials",
        "title": "CP Swiss Knife: Configure API Credentials",
        "icon": "$(key)"
      },
      {
        "command": "codeforces.showProfile",
        "title": "CP Swiss Knife: Show Profile",
        "icon": "$(account)"
      },
      {
        "command": "codeforces.refreshProfile",
        "title": "CP Swiss Knife: Refresh Profile Snapshot",
        "icon": "$(refresh)"
      },
      {
        "command": "codeforces.showRatingGraph",
        "title": "CP Swiss Knife: Show Rating Graph",
        "icon": "$(graph)"
      },
      {
        "command": "codeforces.openProfileOnWeb",
        "title": "CP Swiss Knife: Open Profile on Codeforces",
        "icon": "$(globe)"
      },
      {
        "command": "codeforces.viewProfile",
        "title": "CP Swiss Knife: Focus Profile View",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "codeforces.refreshProblems",
        "title": "CP Swiss Knife: Refresh Problems",
        "icon": "$(refresh)"
      },
      {
        "command": "codeforces.openProblem",
        "title": "CP Swiss Knife: Open Problem"
      },
      {
        "command": "codeforces.searchProblem",
        "title": "CP Swiss Knife: Search Problems",
        "icon": "$(search)"
      },
      {
        "command": "codeforces.previewProblem",
        "title": "CP Swiss Knife: Preview Problem",
        "icon": "$(preview)"
      },
      {
        "command": "codeforces.openProblemInVsCode",
        "title": "CP Swiss Knife: Open Problem in VS Code"
      },
      {
        "command": "codeforces.submit",
        "title": "CP Swiss Knife: Submit Solution",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "codeforces.runTests",
        "title": "CP Swiss Knife: Run Sample Tests",
        "icon": "$(play)"
      },
      {
        "command": "codeforces.customTest",
        "title": "CP Swiss Knife: Run Custom Test",
        "icon": "$(beaker)"
      },
      {
        "command": "codeforces.importSamplesFromClipboard",
        "title": "CP Swiss Knife: Import Samples From Clipboard",
        "icon": "$(clippy)"
      },
      {
        "command": "codeforces.refreshContests",
        "title": "CP Swiss Knife: Refresh Contests",
        "icon": "$(refresh)"
      },
      {
        "command": "codeforces.openContest",
        "title": "CP Swiss Knife: Open Contest"
      },
      {
        "command": "codeforces.registerContest",
        "title": "CP Swiss Knife: Register for Contest"
      },
      {
        "command": "codeforces.viewStandings",
        "title": "CP Swiss Knife: View Standings"
      },
      {
        "command": "codeforces.virtualContest",
        "title": "CP Swiss Knife: Start Virtual Contest"
      },
      {
        "command": "codeforces.viewContests",
        "title": "CP Swiss Knife: Focus Contests View"
      },
      {
        "command": "codeforces.viewSubmissions",
        "title": "CP Swiss Knife: View Submissions"
      },
      {
        "command": "codeforces.openEditorial",
        "title": "CP Swiss Knife: Open Editorial"
      },
      {
        "command": "codeforces.setLanguage",
        "title": "CP Swiss Knife: Set Default Language"
      },
      {
        "command": "codeforces.starProblem",
        "title": "CP Swiss Knife: Star Problem",
        "icon": "$(star-empty)"
      },
      {
        "command": "codeforces.unstarProblem",
        "title": "CP Swiss Knife: Unstar Problem",
        "icon": "$(star-full)"
      },
      {
        "command": "codeforces.filterByTag",
        "title": "CP Swiss Knife: Filter by Tag"
      },
      {
        "command": "codeforces.filterByRating",
        "title": "CP Swiss Knife: Filter by Rating"
      },
      {
        "command": "codeforces.clearFilters",
        "title": "CP Swiss Knife: Clear Filters"
      },
      {
        "command": "codeforces.markProblemAsSolved",
        "title": "CP Swiss Knife: Mark Problem as Solved",
        "icon": "$(check)"
      },
      {
        "command": "codeforces.unmarkProblemAsSolved",
        "title": "CP Swiss Knife: Unmark Problem as Solved",
        "icon": "$(circle-slash)"
      },
      {
        "command": "codeforces.openProblemOnWeb",
        "title": "CP Swiss Knife: Open Problem on Codeforces",
        "icon": "$(globe)"
      },
      {
        "command": "codeforces.viewProblemSubmissions",
        "title": "CP Swiss Knife: View Problem Submissions",
        "icon": "$(history)"
      },
      {
        "command": "codeforces.refreshSubmissions",
        "title": "CP Swiss Knife: Refresh Submissions",
        "icon": "$(refresh)"
      },
      {
        "command": "codeforces.filterSubmissions",
        "title": "CP Swiss Knife: Filter Submissions"
      },
      {
        "command": "codeforces.showSolvedProblems",
        "title": "CP Swiss Knife: Show Solved Problems",
        "icon": "$(checklist)"
      },
      {
        "command": "codeforces.showStandings",
        "title": "CP Swiss Knife: Show Standings"
      },
      {
        "command": "codeforces.dailyProblem",
        "title": "CP Swiss Knife: Daily Problem",
        "icon": "$(calendar)"
      },
      {
        "command": "codeforces.editTemplate",
        "title": "CP Swiss Knife: Edit Language Template",
        "icon": "$(edit)"
      },
      {
        "command": "codeforces.resetTemplate",
        "title": "CP Swiss Knife: Reset Language Template to Default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeforces",
          "title": "CP Swiss Knife",
          "icon": "media/codeforces.svg"
        }
      ]
    },
    "views": {
      "codeforces": [
        {
          "type": "webview",
          "id": "codeforcesUserDashboard",
          "name": "Profile",
          "icon": "media/codeforces.svg"
        },
        {
          "id": "codeforcesProblems",
          "name": "Problems",
          "icon": "media/codeforces.svg"
        },
        {
          "id": "codeforcesContests",
          "name": "Contests",
          "icon": "media/codeforces.svg"
        },
        {
          "id": "codeforcesSubmissions",
          "name": "Submissions",
          "icon": "media/codeforces.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codeforcesUserDashboard",
        "contents": "Welcome to CP Swiss Knife!\n[Login](command:codeforces.login)\nLogin to view your profile, submit solutions, and track your progress.",
        "when": "!codeforces.isLoggedIn"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeforces.refreshProblems",
          "when": "view == codeforcesProblems",
          "group": "navigation"
        },
        {
          "command": "codeforces.searchProblem",
          "when": "view == codeforcesProblems",
          "group": "navigation"
        },
        {
          "command": "codeforces.refreshContests",
          "when": "view == codeforcesContests",
          "group": "navigation"
        },
        {
          "command": "codeforces.refreshSubmissions",
          "when": "view == codeforcesSubmissions",
          "group": "navigation"
        },
        {
          "command": "codeforces.login",
          "when": "view == codeforcesUser && !codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.showProfile",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.refreshProfile",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.showRatingGraph",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.showSolvedProblems",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.openProfileOnWeb",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.configureApiCredentials",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        },
        {
          "command": "codeforces.logout",
          "when": "view == codeforcesUser && codeforces.isLoggedIn",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codeforces.openProblem",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "inline"
        },
        {
          "command": "codeforces.previewProblem",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "navigation@1"
        },
        {
          "command": "codeforces.openProblemOnWeb",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "navigation@2"
        },
        {
          "command": "codeforces.viewProblemSubmissions",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "navigation@3"
        },
        {
          "command": "codeforces.markProblemAsSolved",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "actions@1"
        },
        {
          "command": "codeforces.starProblem",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "actions@2"
        },
        {
          "command": "codeforces.unstarProblem",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "actions@3"
        },
        {
          "command": "codeforces.unmarkProblemAsSolved",
          "when": "view == codeforcesProblems && viewItem == problem",
          "group": "actions@4"
        },
        {
          "command": "codeforces.openContest",
          "when": "view == codeforcesContests && viewItem == contest",
          "group": "inline"
        },
        {
          "command": "codeforces.registerContest",
          "when": "view == codeforcesContests && viewItem == upcomingContest"
        },
        {
          "command": "codeforces.viewStandings",
          "when": "view == codeforcesContests && viewItem == contest"
        }
      ],
      "editor/title": [
        {
          "command": "codeforces.submit",
          "when": "resourceFilename =~ /^cf_.*$/",
          "group": "navigation@1"
        },
        {
          "command": "codeforces.runTests",
          "when": "resourceFilename =~ /^cf_.*$/",
          "group": "navigation@2"
        },
        {
          "command": "codeforces.customTest",
          "when": "resourceFilename =~ /^cf_.*$/",
          "group": "navigation@3"
        },
        {
          "command": "codeforces.previewProblem",
          "when": "resourceFilename =~ /^cf_.*$/",
          "group": "navigation@4"
        },
        {
          "command": "codeforces.importSamplesFromClipboard",
          "when": "resourceFilename =~ /^cf_.*$/",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "CP Swiss Knife",
      "properties": {
        "codeforces.handle": {
          "type": "string",
          "default": "",
          "description": "Your Codeforces handle"
        },
        "codeforces.author": {
          "type": "string",
          "default": "",
          "description": "Your name or handle to include in generated solution file headers ({author} placeholder)"
        },
        "codeforces.workspaceFolder": {
          "type": "string",
          "default": "",
          "description": "Folder to store solution files (default: ~/.codeforces)"
        },
        "codeforces.defaultLanguage": {
          "type": "string",
          "default": "cpp",
          "enum": [
            "cpp",
            "python",
            "java",
            "kotlin",
            "rust",
            "go",
            "csharp",
            "javascript"
          ],
          "description": "Default programming language for solutions"
        },
        "codeforces.cppCompiler": {
          "type": "string",
          "default": "g++",
          "description": "C++ compiler command"
        },
        "codeforces.cppFlags": {
          "type": "string",
          "default": "-std=c++17 -O2 -Wall -Wextra",
          "description": "C++ compiler flags"
        },
        "codeforces.pythonCommand": {
          "type": "string",
          "default": "python3",
          "description": "Python interpreter command"
        },
        "codeforces.chromeExecutablePath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a local Chrome/Chromium executable for browser-assisted problem import"
        },
        "codeforces.enableBrowserExtraction": {
          "type": "boolean",
          "default": true,
          "description": "Try browser-assisted problem extraction with local Chrome when direct fetch is blocked"
        },
        "codeforces.javaCommand": {
          "type": "string",
          "default": "java",
          "description": "Java command"
        },
        "codeforces.showDifficultyBadges": {
          "type": "boolean",
          "default": true,
          "description": "Show difficulty badges on problems"
        },
        "codeforces.showSolvedIndicator": {
          "type": "boolean",
          "default": true,
          "description": "Show solved indicator on problems"
        },
        "codeforces.contestReminders": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications before contests start"
        },
        "codeforces.reminderMinutesBefore": {
          "type": "number",
          "default": 15,
          "description": "Minutes before contest to show reminder"
        },
        "codeforces.autoOpenContestProblems": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open all problems when contest starts"
        },
        "codeforces.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Codeforces status bar item"
        },
        "codeforces.includeGym": {
          "type": "boolean",
          "default": false,
          "description": "Include Gym contests in contest list"
        },
        "codeforces.friendHandles": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "List of friend handles to track"
        },
        "codeforces.template.cpp": {
          "type": "string",
          "default": "",
          "description": "Path to custom C++ template file"
        },
        "codeforces.template.python": {
          "type": "string",
          "default": "",
          "description": "Path to custom Python template file"
        },
        "codeforces.template.java": {
          "type": "string",
          "default": "",
          "description": "Path to custom Java template file"
        }
      }
    },
    "keybindings": [
      {
        "command": "codeforces.submit",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      },
      {
        "command": "codeforces.runTests",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus"
      },
      {
        "command": "codeforces.previewProblem",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run bundle",
    "bundle": "node ./esbuild.mjs",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && mocha --require ./out/test/register-mock.js --ui tdd --timeout 10000 './out/test/suite/**/*.test.js'",
    "package": "vsce package",
    "publish": "vsce publish",
    "release": "./scripts/release.sh"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.55.0",
    "mocha": "^10.2.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "playwright-core": "^1.58.2"
  }
}
